        {
          "name": "ok-one-way-binding",
          "pattern": {
            "regex": "^:[-\\w.:@]+"
          },
          "description": "OK.js one-way binding — value is evaluated as a JS expression and reactively applied to the property/attribute."
        },
        {
          "name": "ok-two-way-binding",
          "pattern": {
            "regex": "^![-\\w.:]+"
          },
          "description": "OK.js two-way binding — creates a bidirectional reactive link between the expression and the element property."
        },
        {
          "name": "ok-event-handler",
          "pattern": {
            "regex": "^@[-\\w.]+(?::[-\\w.]+)*"
          },
          "description": "OK.js event handler — value is a JS expression executed when the event fires. Append :prevent, :stop, :once, etc. as modifiers."
        },
        {
          "name": "ok-let-binding",
          "pattern": {
            "regex": "^let:[-\\w]+"
          },
          "description": "OK.js let-binding — exposes a named variable from the enclosing component primitive into the inner scope."
        },
        {
          "name": "ok-spread-binding",
          "pattern": {
            "regex": "^\\.\\.\\.[-\\w]+"
          },
          "description": "OK.js spread binding — spreads an object of attributes onto the element."
        }
